---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = '/images/og-image.jpg' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <meta property="og:locale" content="en_MY" />
  </head>

  <body>
    <!-- Navigation -->
    <nav class="navbar">
      <div class="container nav-inner">
        <a href="/" class="nav-logo">
          <img src="/images/logo.png" alt="ATECH Sustainability Consultancy" height="40" />
        </a>
        <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </button>
        <ul class="nav-links" id="navLinks">
          <li><a href="/">Home</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/ai-audit" class="nav-ai">⚡ AI Tools</a></li>
          <li><a href="/pricing">Pricing</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact" class="nav-cta">Get in Touch</a></li>
        </ul>
      </div>
    </nav>

    <!-- Page content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <img src="/images/logo.png" alt="ATECH" height="32" />
          <p>ATECH Sustainability Consultancy<br />MAESCO Gold Award Winner 2025</p>
        </div>
        <div class="footer-links">
          <h4>Services</h4>
          <ul>
            <li><a href="/services#energy-management">Energy Management</a></li>
            <li><a href="/services#training">HRDC Training</a></li>
            <li><a href="/services#rem-mentorship">REM Mentorship</a></li>
            <li><a href="/services#financing">Sustainability Financing</a></li>
          </ul>
        </div>
        <div class="footer-links">
          <h4>Company</h4>
          <ul>
            <li><a href="/about">About</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div class="footer-contact">
          <h4>Contact</h4>
          <p>Malaysia (Nationwide)</p>
          <a href="/contact">Request a Quote →</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© {new Date().getFullYear()} ATECH Sustainability Consultancy. All rights reserved.</p>
      </div>
    </footer>

    <script>
      // Mobile nav toggle
      const toggle = document.getElementById('navToggle');
      const links = document.getElementById('navLinks');
      toggle?.addEventListener('click', () => links?.classList.toggle('open'));

      // Navbar shadow on scroll
      const navbar = document.querySelector('.navbar');
      window.addEventListener('scroll', () => {
        navbar?.classList.toggle('scrolled', window.scrollY > 24);
      }, { passive: true });

      // Scroll-reveal: individual elements with data-reveal
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12 });

      document.querySelectorAll('[data-reveal]').forEach(el => revealObserver.observe(el));

      // Staggered children: data-stagger container
      const staggerObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.querySelectorAll(':scope > *').forEach((child, i) => {
              setTimeout(() => child.classList.add('visible'), i * 110);
            });
            staggerObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08 });

      document.querySelectorAll('[data-stagger]').forEach(el => staggerObserver.observe(el));

      // Animated stat counters
      const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          entry.target.querySelectorAll('[data-count]').forEach(el => {
            const target = +el.dataset.count;
            let cur = 0;
            const step = Math.ceil(target / 40);
            const timer = setInterval(() => {
              cur = Math.min(cur + step, target);
              el.textContent = cur + '+';
              if (cur >= target) clearInterval(timer);
            }, 35);
          });
          counterObserver.unobserve(entry.target);
        });
      }, { threshold: 0.3 });
      document.querySelectorAll('.ai-stats').forEach(el => counterObserver.observe(el));

      // Terminal typing animation
      const terminal = document.getElementById('terminal-body');
      if (terminal) {
        const lines = [
          { text: '> Loading workbook: OfficeBuilding_Audit.xlsx', cls: 'cmd', delay: 400 },
          { text: '  13 sheets parsed  ·  audit_master built', cls: 'info', delay: 900 },
          { text: '> Retrieving learning memory (3 examples)...', cls: 'cmd', delay: 1500 },
          { text: '> Generating Section 7.6: Regression Analysis', cls: 'cmd', delay: 2200 },
          { text: '', cls: 'dim', delay: 2700 },
          { text: '  The baseline energy consumption was established using', cls: 'out', delay: 2800 },
          { text: '  12-month historical data from Jan–Dec 2024. A regression', cls: 'out', delay: 3300 },
          { text: '  analysis was performed correlating monthly energy (kWh)', cls: 'out', delay: 3800 },
          { text: '  against Cooling Degree Days. The resulting model yields', cls: 'out', delay: 4300 },
          { text: '  R² = 0.912, confirming a strong predictive relationship', cls: 'out', delay: 4800 },
          { text: '  and satisfying Audit Standard Rule 3.', cls: 'out', delay: 5300 },
          { text: '', cls: 'dim', delay: 5700 },
          { text: '  ✓  Ground Rule 3 satisfied  (R² ≥ 0.75)', cls: 'gold', delay: 5900 },
          { text: '> Section approved  ·  Next: Section 7.7...', cls: 'cmd', delay: 6600 },
        ];

        const termObserver = new IntersectionObserver((entries) => {
          if (!entries[0].isIntersecting) return;
          terminal.innerHTML = '';
          lines.forEach(({ text, cls, delay }) => {
            setTimeout(() => {
              const span = document.createElement('span');
              span.className = 'terminal-line ' + cls;
              span.textContent = text;
              terminal.appendChild(span);
              terminal.scrollTop = terminal.scrollHeight;
            }, delay);
          });
          // restart loop
          setTimeout(() => {
            terminal.innerHTML = '<span class="terminal-line dim">Initialising ATECH Energy Audit AI...</span>';
            setTimeout(() => {
              lines.forEach(({ text, cls, delay }) => {
                setTimeout(() => {
                  const span = document.createElement('span');
                  span.className = 'terminal-line ' + cls;
                  span.textContent = text;
                  terminal.appendChild(span);
                  terminal.scrollTop = terminal.scrollHeight;
                }, delay);
              });
            }, 800);
          }, 9000);
          termObserver.unobserve(entries[0].target);
        }, { threshold: 0.3 });
        termObserver.observe(terminal);
      }
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --teal: #06B6D4;
    --teal-dark: #0891B2;
    --navy: #0F0F23;
    --gold: #C8960C;
    --gold-dark: #A07A08;
    --gold-light: #FFF3CD;
    --violet: #A78BFA;
    --light: #F0FDFF;
    --border: #BAE6FD;
    --text: #1E1B4B;
    --muted: #64748B;
    --white: #ffffff;
    --font: 'Inter', system-ui, sans-serif;
    --radius: 10px;
    --shadow: 0 2px 16px rgba(0,0,0,0.08);
    --max-w: 1100px;
    --transition: 0.2s ease;
  }

  html { font-family: var(--font); color: var(--text); scroll-behavior: smooth; }
  body { background: var(--white); line-height: 1.6; }
  img { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }

  .container { max-width: var(--max-w); margin: 0 auto; padding: 0 1.5rem; }

  /* ── Navbar ── */
  .navbar {
    position: sticky; top: 0; z-index: 100;
    background: var(--white); border-bottom: 1px solid var(--border);
    box-shadow: 0 1px 8px rgba(0,0,0,0.06);
  }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .nav-logo img { height: 40px; width: auto; }
  .nav-links { display: flex; gap: 2rem; list-style: none; align-items: center; }
  .nav-links a { font-weight: 500; color: var(--navy); transition: color var(--transition); }
  .nav-links a:hover { color: var(--teal); }
  .nav-ai {
    color: var(--teal) !important; font-weight: 600;
    border: 1.5px solid var(--teal); border-radius: 6px;
    padding: 0.4rem 0.9rem;
    transition: background var(--transition), color var(--transition);
  }
  .nav-ai:hover { background: var(--teal) !important; color: var(--white) !important; }
  .nav-cta {
    background: var(--teal); color: var(--white) !important;
    padding: 0.5rem 1.2rem; border-radius: 6px;
    transition: background var(--transition);
  }
  .nav-cta:hover { background: var(--teal-dark) !important; }

  /* ── AI Section ── */
  .ai-section { background: linear-gradient(180deg, #0F0F23 0%, #0D1B3A 100%); color: var(--white); padding: 5rem 0; }
  .ai-section h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); text-align: center; margin-bottom: 0.5rem; }
  .ai-section .ai-sub { text-align: center; color: rgba(255,255,255,0.6); margin-bottom: 3rem; max-width: 560px; margin-left: auto; margin-right: auto; }

  /* Stats bar */
  .ai-stats { display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap; margin-bottom: 3.5rem; }
  .ai-stat { text-align: center; }
  .ai-stat-num { font-size: 2rem; font-weight: 800; color: var(--teal); display: block; line-height: 1; }
  .ai-stat-label { font-size: 0.8rem; color: rgba(255,255,255,0.55); text-transform: uppercase; letter-spacing: 0.06em; margin-top: 0.3rem; }

  /* Terminal window */
  .terminal-wrap { max-width: 760px; margin: 0 auto 3.5rem; border-radius: 12px; overflow: hidden; box-shadow: 0 24px 60px rgba(0,0,0,0.6); }
  .terminal-bar { background: #2d2d2d; padding: 0.65rem 1rem; display: flex; align-items: center; gap: 0.5rem; }
  .terminal-dot { width: 12px; height: 12px; border-radius: 50%; }
  .terminal-dot.red { background: #ff5f57; }
  .terminal-dot.yellow { background: #febc2e; }
  .terminal-dot.green { background: #28c840; }
  .terminal-title { font-size: 0.75rem; color: rgba(255,255,255,0.4); margin-left: auto; margin-right: auto; font-family: monospace; }
  .terminal-body { background: #0d1117; padding: 1.5rem; font-family: 'Courier New', monospace; font-size: 0.85rem; line-height: 1.7; min-height: 220px; }
  .terminal-line { display: block; }
  .terminal-line.cmd { color: #06B6D4; }
  .terminal-line.info { color: #A78BFA; }
  .terminal-line.out { color: #e6edf3; }
  .terminal-line.gold { color: #F59E0B; font-weight: 600; }
  .terminal-line.dim { color: rgba(255,255,255,0.3); }
  .terminal-cursor { display: inline-block; width: 8px; height: 1em; background: #06B6D4; vertical-align: text-bottom; animation: blink 1s step-end infinite; }
  @keyframes blink { 0%,100% { opacity:1; } 50% { opacity:0; } }

  /* AI Tool cards */
  .ai-tools-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-top: 0; }
  .ai-tool-card {
    background: rgba(255,255,255,0.04); border: 1px solid rgba(6,182,212,0.25);
    border-radius: 14px; padding: 2rem; display: flex; flex-direction: column; gap: 1rem;
    transition: border-color 0.3s, background 0.3s, transform 0.3s;
  }
  .ai-tool-card:hover { border-color: var(--teal); background: rgba(6,182,212,0.07); transform: translateY(-4px); }
  .ai-tool-icon { font-size: 2.2rem; }
  .ai-tool-card h3 { font-size: 1.2rem; color: var(--teal); margin: 0; }
  .ai-tool-card p { color: rgba(255,255,255,0.65); font-size: 0.95rem; flex: 1; margin: 0; }
  .ai-tool-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .ai-tag { background: rgba(6,182,212,0.15); border: 1px solid rgba(6,182,212,0.3); border-radius: 4px; padding: 0.2rem 0.6rem; font-size: 0.72rem; color: var(--teal); text-transform: uppercase; letter-spacing: 0.05em; }
  .ai-tool-link { color: var(--teal); font-weight: 600; font-size: 0.9rem; display: inline-flex; align-items: center; gap: 0.3rem; margin-top: auto; transition: gap 0.2s; }
  .ai-tool-link:hover { gap: 0.6rem; }


  /* AI Tools page */
  .ai-hero { background: linear-gradient(135deg, #0F0F23 0%, #0D1B3A 100%); color: var(--white); padding: 5rem 0; text-align: center; }
  .ai-hero h1 { font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1rem; animation: fadeUp 0.8s ease 0.2s both; }
  .ai-hero p { color: rgba(255,255,255,0.75); max-width: 580px; margin: 0 auto; animation: fadeUp 0.8s ease 0.4s both; }
  .how-it-works { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr)); gap: 1.5rem; counter-reset: steps; }
  .how-step { background: var(--light); border-radius: var(--radius); padding: 1.8rem; position: relative; }
  .how-step::before { counter-increment: steps; content: counter(steps); position: absolute; top: -14px; left: 1.5rem; background: var(--teal); color: white; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; }
  .how-step h4 { color: var(--navy); margin-bottom: 0.5rem; }
  .how-step p { color: var(--muted); font-size: 0.9rem; margin: 0; }
  .nav-toggle { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; }
  .nav-toggle span { display: block; width: 24px; height: 2px; background: var(--navy); }

  @media (max-width: 700px) {
    .nav-toggle { display: flex; }
    .nav-links {
      display: none; flex-direction: column; gap: 0;
      position: absolute; top: 64px; left: 0; right: 0;
      background: var(--white); border-bottom: 1px solid var(--border);
      padding: 1rem 0;
    }
    .nav-links.open { display: flex; }
    .nav-links li { width: 100%; text-align: center; padding: 0.75rem 0; }
  }

  /* ── Navbar scroll effect ── */
  .navbar { transition: box-shadow 0.3s ease, background 0.3s ease; }
  .navbar.scrolled { box-shadow: 0 2px 24px rgba(0,0,0,0.12); }

  /* ── Buttons ── */
  .btn-primary, .btn-secondary {
    display: inline-block; padding: 0.8rem 1.8rem;
    border-radius: 8px; font-weight: 600; font-size: 1rem;
    transition: all var(--transition); cursor: pointer;
  }
  .btn-primary { background: var(--teal); color: var(--white); position: relative; overflow: hidden; }
  .btn-primary::after {
    content: ''; position: absolute; top: 0; left: -100%;
    width: 60%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
    transform: skewX(-20deg);
    animation: shimmer 3s ease 1.2s infinite;
  }
  .btn-primary:hover { background: var(--teal-dark); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(6,182,212,0.4); }
  .btn-secondary { background: transparent; color: var(--teal); border: 2px solid var(--teal); }
  .btn-secondary:hover { background: var(--teal); color: var(--white); }

  /* ── Keyframes ── */
  @keyframes fadeUp   { from { opacity:0; transform:translateY(32px); } to { opacity:1; transform:translateY(0); } }
  @keyframes fadeIn   { from { opacity:0; } to { opacity:1; } }
  @keyframes gradientShift { 0%,100% { background-position:0% 50%; } 50% { background-position:100% 50%; } }
  @keyframes badgePulse { 0%,100% { box-shadow:0 0 0 0 rgba(255,255,255,0.25); } 60% { box-shadow:0 0 0 10px rgba(255,255,255,0); } }
  @keyframes shimmer  { 0% { left:-100%; } 100% { left:150%; } }
  @keyframes floatUp  { 0%,100% { transform:translateY(0); } 50% { transform:translateY(-6px); } }

  /* ── Scroll-reveal base ── */
  [data-reveal] { opacity:0; transform:translateY(28px); transition:opacity 0.65s ease, transform 0.65s ease; }
  [data-reveal="left"]  { transform:translateX(-36px); }
  [data-reveal="right"] { transform:translateX(36px); }
  [data-reveal="scale"] { transform:scale(0.93); }
  [data-reveal].visible { opacity:1; transform:none; }

  /* Stagger delays for card children */
  [data-stagger] > * { opacity:0; transform:translateY(24px); transition:opacity 0.5s ease, transform 0.5s ease; }
  [data-stagger] > *.visible { opacity:1; transform:none; }
  [data-stagger] > *:nth-child(1) { transition-delay:0s; }
  [data-stagger] > *:nth-child(2) { transition-delay:0.1s; }
  [data-stagger] > *:nth-child(3) { transition-delay:0.2s; }
  [data-stagger] > *:nth-child(4) { transition-delay:0.3s; }

  /* ── Hero ── */
  .hero {
    background: linear-gradient(135deg, #0F0F23 0%, #1A1A3E 45%, #0D2D3A 100%);
    background-size: 300% 300%;
    animation: gradientShift 10s ease infinite;
    color: var(--white); padding: 6rem 0; text-align: center;
    position: relative; overflow: hidden;
  }
  .award-badge {
    display: inline-block;
    background: linear-gradient(135deg, var(--gold), #e8b020);
    border: none;
    border-radius: 20px;
    padding: 0.45rem 1.1rem; font-size: 0.9rem; font-weight: 600;
    color: #3d2600; margin-bottom: 1.5rem;
    box-shadow: 0 2px 12px rgba(200,150,12,0.4);
    animation: fadeIn 0.7s ease both, badgePulse 3.5s ease 1.5s infinite;
  }
  .hero h1 {
    font-size: clamp(1.8rem, 4vw, 3rem); font-weight: 700; line-height: 1.2;
    margin-bottom: 1.2rem; max-width: 720px; margin-left: auto; margin-right: auto;
    animation: fadeUp 0.8s ease 0.2s both;
  }
  .lead {
    font-size: 1.15rem; color: rgba(255,255,255,0.85); max-width: 600px;
    margin: 0 auto 2rem;
    animation: fadeUp 0.8s ease 0.4s both;
  }
  .cta-group { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; animation: fadeUp 0.8s ease 0.6s both; }

  /* ── Award Section ── */
  .award-section { padding: 5rem 0; background: var(--light); }
  .award-section .container { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
  .award-section img { border-radius: var(--radius); box-shadow: var(--shadow); }
  .award-section h2 { font-size: 1.8rem; color: var(--navy); margin-bottom: 1rem; padding-left: 1rem; border-left: 4px solid var(--gold); }
  .award-section p { color: var(--muted); margin-bottom: 0.75rem; }
  .award-section strong { color: var(--gold-dark); }
  @media (max-width: 700px) { .award-section .container { grid-template-columns: 1fr; } }

  /* ── Services ── */
  .services { padding: 5rem 0; text-align: center; }
  .services h2 { font-size: 2rem; color: var(--navy); margin-bottom: 0.5rem; }
  .section-intro { color: var(--muted); max-width: 560px; margin: 0 auto 2.5rem; }
  .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; text-align: left; }
  .service-card {
    background: var(--white); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 1.8rem; display: flex; flex-direction: column; gap: 0.75rem;
    transition: box-shadow 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
  }
  .service-card:hover {
    box-shadow: 0 8px 32px rgba(6,182,212,0.18);
    transform: translateY(-6px);
    border-color: var(--teal);
  }
  .service-card:hover h3 { color: var(--teal); transition: color 0.2s ease; }
  .service-card:hover .learn-more { letter-spacing: 0.03em; transition: letter-spacing 0.2s ease; }
  .service-card h3 { font-size: 1.1rem; color: var(--navy); }
  .service-card p { color: var(--muted); font-size: 0.95rem; flex: 1; }
  .learn-more { color: var(--teal); font-weight: 600; font-size: 0.9rem; }

  /* ── Why Us ── */
  .why-us { background: linear-gradient(135deg, #0F0F23 0%, #1A1A4E 100%); color: var(--white); padding: 5rem 0; text-align: center; }
  .why-us h2 { font-size: 2rem; margin-bottom: 1rem; }
  .why-us p { max-width: 600px; margin: 0 auto 2rem; opacity: 0.9; }
  .why-us .btn-secondary { color: var(--white); border-color: rgba(255,255,255,0.7); }
  .why-us .btn-secondary:hover { background: var(--white); color: var(--teal-dark); }

  /* ── FAQ ── */
  .faq { padding: 5rem 0; }
  .faq h2 { font-size: 2rem; color: var(--navy); text-align: center; margin-bottom: 2.5rem; }
  .faq details { border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 1rem; overflow: hidden; }
  .faq summary { padding: 1.2rem 1.5rem; font-weight: 600; color: var(--navy); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq summary::after { content: '+'; font-size: 1.4rem; color: var(--teal); }
  .faq details[open] summary::after { content: '−'; }
  .faq details div { padding: 0 1.5rem 1.2rem; color: var(--muted); animation: fadeUp 0.3s ease both; }
  .faq details div ul { padding-left: 1.5rem; margin-top: 0.5rem; }
  .faq details div li { margin-bottom: 0.4rem; }
  .faq details div a { color: var(--teal); text-decoration: underline; }
  .faq details { transition: box-shadow 0.2s ease; }
  .faq details[open] { box-shadow: 0 4px 16px rgba(6,182,212,0.12); border-color: var(--teal); }

  /* ── Contact CTA ── */

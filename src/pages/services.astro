---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Our Services | ATECH Sustainability Consultancy"
  description="Energy audits, HRDC-claimable sustainability training, REM mentorship, and green financing advisory for Malaysian organisations."
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <h1>Our Services</h1>
      <p>Comprehensive energy and sustainability solutions for Malaysian businesses.</p>
    </div>
  </section>

  <!-- ── Gallery Intro ─────────────────────────────────────────────── -->
  <section class="gallery-section">
    <div class="container gallery-wrap">

      <!-- Left: CTA text -->
      <div class="gallery-text">
        <span class="gallery-label blur-reveal" style="transition-delay:0s">Our Expertise</span>
        <h2 class="blur-reveal" style="transition-delay:0.1s">
          Transforming Energy &amp; Sustainability for Malaysian Organisations
        </h2>
        <p class="blur-reveal" style="transition-delay:0.2s">
          From rigorous energy audits to HRDC-claimable training and AI-powered
          reporting tools, delivering measurable results for facilities across
          Malaysia.
        </p>
        <div class="blur-reveal" style="transition-delay:0.3s">
          <a href="/contact" class="btn-primary">Start Your Energy Journey</a>
        </div>
      </div>

      <!-- Right: 4-image mosaic grid -->
      <div class="gallery-grid">
        <div class="g-cell blur-reveal" style="transition-delay:0s; grid-area:1/2/3/3;">
          <img src="/images/services/energy-management-2.jpg"
               alt="Energy management site audit" loading="lazy" />
        </div>
        <div class="g-cell blur-reveal" style="transition-delay:0.2s; grid-area:2/1/4/2;">
          <img src="/images/services/energy-management.jpg"
               alt="On-site energy assessment" loading="lazy" />
        </div>
        <div class="g-cell blur-reveal" style="transition-delay:0.4s; grid-area:4/1/6/2;">
          <img src="/images/services/hrdc-training.jpg"
               alt="HRDC-claimable sustainability training session" loading="lazy" />
        </div>
        <div class="g-cell blur-reveal" style="transition-delay:0.6s; grid-area:3/2/5/3;">
          <img src="/images/services/rem-mentoring.jpg"
               alt="REM mentorship programme" loading="lazy" />
        </div>
      </div>

    </div>
  </section>

  <!-- ── Energy Management ─────────────────────────────────────────── -->
  <section class="svc-section" id="energy-management">
    <div class="container svc-wrap">

      <div class="svc-img blur-reveal" style="transition-delay:0s">
        <img src="/images/services/energy-management-2.jpg"
             alt="Energy audit site inspection" loading="lazy" />
      </div>

      <div class="svc-text">
        <span class="svc-label">01</span>
        <h2 data-reveal>Energy Management</h2>
        <p>
          Our energy management service begins with a rigorous energy audit compliant with
          government energy audit standards. We assess your facility's energy consumption,
          identify inefficiencies, and propose targeted Energy Saving Measures (ESMs)
          with verified savings projections and payback periods.
        </p>
        <p>
          Each audit is backed by our <strong>Sustainable Energy Management Program (SEMP)</strong>,
          which provides a roadmap from baseline measurement to ongoing monitoring and
          verification (M&amp;V).
        </p>
        <ul class="svc-list">
          <li>Government-compliant energy audits (Level 1, 2, 3)</li>
          <li>Building Energy Intensity (BEI) benchmarking</li>
          <li>Energy Saving Measures with financial analysis</li>
          <li>Monitoring &amp; Verification (M&amp;V) planning</li>
          <li>EECA compliance support</li>
        </ul>
        <a href="/contact" class="btn-primary">Request an Audit</a>
      </div>

    </div>
  </section>

  <!-- ── HRDC Training ─────────────────────────────────────────────── -->
  <section class="svc-section svc-alt" id="training">
    <div class="container svc-wrap svc-wrap-rev">

      <div class="svc-text">
        <span class="svc-label">02</span>
        <h2 data-reveal>HRDC-Claimable Training</h2>
        <p>
          Our training programs are registered with <strong>HRD Corp</strong>, enabling
          Malaysian employers to claim costs through their HRDC levy. We offer practical,
          practical courses designed for facility managers, engineers, and
          sustainability teams.
        </p>
        <ul class="svc-list">
          <li>Energy Auditing Fundamentals</li>
          <li>Greenhouse Gas (GHG) Accounting &amp; Reporting</li>
          <li>EECA Compliance &amp; Energy Management Systems</li>
          <li>Sustainability Reporting (ESG, GRI, TCFD)</li>
          <li>Custom in-house training programmes</li>
        </ul>
        <a href="/contact" class="btn-primary">Enquire About Training</a>
      </div>

      <div class="svc-img blur-reveal" style="transition-delay:0s">
        <img src="/images/services/hrdc-training.jpg"
             alt="HRDC sustainability training session" loading="lazy" />
      </div>

    </div>
  </section>

  <!-- ── REM Mentorship ────────────────────────────────────────────── -->
  <section class="svc-section" id="rem-mentorship">
    <div class="container svc-wrap">

      <div class="svc-img blur-reveal" style="transition-delay:0s">
        <img src="/images/services/rem-mentoring.jpg"
             alt="Registered Energy Manager mentorship" loading="lazy" />
      </div>

      <div class="svc-text">
        <span class="svc-label">03</span>
        <h2 data-reveal>REM Appointment &amp; Mentoring Programme</h2>
        <p>
          Under Malaysia's <strong>Energy Efficiency and Conservation Act (EECA) 2023</strong>,
          designated energy consumers are required to appoint a
          <strong>Registered Energy Manager (REM)</strong>. Currently, this obligation
          can be fulfilled through an <strong>outsourced REM</strong>, a practical,
          cost-effective solution for organisations that do not yet have a certified
          energy manager in-house.
        </p>
        <p>
          Regulatory direction indicates that <strong>in-house REM appointments may
          become mandatory from 2027 onwards</strong> (subject to policy updates).
          ATECH supports you on both fronts: we provide outsourced REM services for
          immediate compliance today, while our structured mentoring programme prepares
          your engineers for REM certification before the transition deadline.
        </p>
        <ul class="svc-list">
          <li>Outsourced REM appointment for immediate EECA compliance</li>
          <li>Structured 1-on-1 REM exam preparation mentorship</li>
          <li>EMGS framework implementation guidance</li>
          <li>EECA 2023 compliance strategy advisory</li>
          <li>Live audit observation and field feedback</li>
          <li>In-house REM transition planning (post-2027 readiness)</li>
        </ul>
        <a href="/contact" class="btn-primary">Enquire About REM Services</a>
      </div>

    </div>
  </section>

  <!-- ── Sustainability Financing ──────────────────────────────────── -->
  <section class="svc-section svc-alt" id="financing">
    <div class="container svc-wrap svc-wrap-rev">

      <div class="svc-text">
        <span class="svc-label">04</span>
        <h2 data-reveal>Sustainability Financing</h2>
        <p>
          Accessing green financing can unlock capital for energy upgrades with favourable
          terms. We advise organisations on identifying and applying for the right instruments
          for their sustainability projects.
        </p>
        <ul class="svc-list">
          <li>Green Sukuk and ESG-linked loan advisory</li>
          <li>EACG (Energy Audit Cost Grant) applications</li>
          <li>Government green investment scheme navigation</li>
          <li>ROI analysis for energy improvement projects</li>
        </ul>
        <a href="/contact" class="btn-primary">Explore Financing</a>
      </div>

      <div class="svc-img blur-reveal" style="transition-delay:0s">
        <img src="/images/services/green-financing.jpg"
             alt="Green sustainability financing Malaysia" loading="lazy" />
      </div>

    </div>
  </section>

  <!-- ── Styles ─────────────────────────────────────────────────────── -->
  <style>

    /* ── Blur-reveal animation ── */
    .blur-reveal {
      opacity: 0;
      filter: blur(10px);
      transform: translateY(16px);
      transition: opacity 0.65s ease, filter 0.65s ease, transform 0.65s ease;
    }
    .blur-reveal.visible {
      opacity: 1;
      filter: blur(0);
      transform: translateY(0);
    }

    /* ── Gallery intro section ── */
    .gallery-section { padding: 5rem 0; background: var(--white); }
    .gallery-wrap {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    /* CTA text */
    .gallery-text { display: flex; flex-direction: column; gap: 1.25rem; }
    .gallery-label {
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--teal);
    }
    .gallery-text h2 {
      font-size: clamp(1.5rem, 2.5vw, 2rem);
      color: var(--navy);
      line-height: 1.25;
      margin: 0;
    }
    .gallery-text p { color: var(--muted); line-height: 1.7; margin: 0; }

    /* Mosaic grid — exact layout from the reference component */
    .gallery-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 50px 150px 50px 150px 50px;
      gap: 14px;
    }
    .g-cell {
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 8px 32px rgba(0,0,0,0.14);
    }
    .g-cell img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; }

    /* ── Individual service sections ── */
    .svc-section { padding: 5rem 0; }
    .svc-alt { background: var(--light); }

    .svc-wrap {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }
    .svc-wrap-rev { direction: rtl; }
    .svc-wrap-rev > * { direction: ltr; }

    /* Image block */
    .svc-img {
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 12px 48px rgba(0,0,0,0.12);
      aspect-ratio: 4/3;
    }
    .svc-img img { width: 100%; height: 100%; object-fit: cover; display: block; }

    /* Text block */
    .svc-text { display: flex; flex-direction: column; gap: 1rem; }
    .svc-label {
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      color: var(--teal);
      text-transform: uppercase;
    }
    .svc-text h2 { font-size: clamp(1.4rem, 2.5vw, 1.9rem); color: var(--navy); margin: 0; }
    .svc-text p { color: var(--muted); line-height: 1.7; margin: 0; }
    .svc-text strong { color: var(--navy); }

    /* Feature list */
    .svc-list {
      list-style: none;
      padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 0.5rem;
    }
    .svc-list li {
      display: flex; align-items: center; gap: 0.6rem;
      font-size: 0.93rem; color: var(--muted);
    }
    .svc-list li::before {
      content: '';
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--teal);
      flex-shrink: 0;
    }
    .svc-list-cols { columns: 2; gap: 2rem; display: block; }
    .svc-list-cols li { break-inside: avoid; display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.5rem; }

    @media (max-width: 768px) {
      .gallery-wrap,
      .svc-wrap { grid-template-columns: 1fr; gap: 2rem; }
      .svc-wrap-rev { direction: ltr; }
      .gallery-grid { grid-template-rows: 40px 120px 40px 120px 40px; }
      .svc-list-cols { columns: 1; }
    }
  </style>

  <!-- ── Scripts ───────────────────────────────────────────────────── -->
  <script>
    const blurEls = document.querySelectorAll('.blur-reveal');
    const blurObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          blurObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });
    blurEls.forEach(el => blurObs.observe(el));
  </script>

</BaseLayout>
